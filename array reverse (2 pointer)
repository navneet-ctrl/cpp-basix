
#include<iostream>
using namespace std;

void reverse(int l,int r,int arr[]){
  if (l>=r) return ;
swap(arr[l],arr[r]);
  reverse(l+1,r-1,arr);
  }
int main(){
  int l,r,n;
  cout << "enter array size and the pointers: ";
  cin >> n >> l >> r;
  int arr[n];
  cout << "enter the array the elements: ";
  for(int i=0;i<n;i++){
    cin>> arr[i] ;}

  reverse(l,r,arr);
  for(int i=0;i<n;i++){
    cout << arr[i] << " ";
  }
  return 0;
  }
