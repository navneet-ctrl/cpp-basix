#include<bits/stdc++.h>
using namespace std;
bool palin(int i,string &s){
  if(i>=s.size()/2) return true;
  if(s[i]!=s[s.size()-i-1]) return false;
  return palin(i+1,s);
}
int main(){
string s;
cout <<"enter the string: ";
cin >> s;
if(palin(0,s)){
    cout << "palindrome!";   //IF PALIN GIVES TRUE
}
else cout << "not a palindrome";
return 0;
}
