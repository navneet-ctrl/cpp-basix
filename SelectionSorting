#include<bits/stdc++.h>
using namespace std;
void sort(int arr[],int n){
    for(int i=0;i<n;i++){
        int minindex=i;
        for (int j=i+1;j<n;j++){
            if(arr[j]<arr[minindex]){
                minindex=j;
            }
        }
        swap(arr[i],arr[minindex]);
    }
}
int main(){
    int n;
    cin >> n;
    int arr[n];
    for(int i=0;i<n;i++){
        cin >> arr[i];
    }
    sort(arr,n);
    for(int j=0;j<n;j++){
        cout << arr[j] << " ";
    }
    return 0;
}
