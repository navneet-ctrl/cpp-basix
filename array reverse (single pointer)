#include<iostream>
using namespace std;
void reverse(int i,int n,int arr[]){
    if (i>=n-i-1 ) return ;
swap(arr[i],arr[n-i-1]);
reverse(i+1,n,arr);
}
int main(){
  int n;
cout << "enter the arraay size: ";
cin >> n;
int arr[n];
cout << "enter array elements: ";
for(int i=0;i<n;i++){
cin >> arr[i];
}
reverse(0,n,arr);
for(int i=0;i<n;i++){
cout << arr[i];}
return 0;
}

